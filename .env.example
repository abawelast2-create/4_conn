# ⚙️ إعدادات البريد الإلكتروني
# انسخ هذا الملف إلى .env وأدخل بياناتك

# البريد الإلكتروني الذي سيُرسل منه (Hostinger Business Email)
EMAIL_USER=your-email@yourdomain.com

# كلمة مرور البريد الإلكتروني من Hostinger
# للحصول عليها:
# 1. اذهب إلى لوحة تحكم Hostinger
# 2. Business Email → إدارة
# 3. استخدم كلمة مرور حساب البريد مباشرة
# (ليست كلمة مرور لوحة التحكم، بل كلمة مرور البريد نفسه)
EMAIL_PASSWORD=your-email-password
